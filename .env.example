# Neon Postgres
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# TheRock poll (server-side only — Vercel env vars)
GITHUB_TOKEN=github_pat_xxx
# owner/repo only — NOT a full URL (wrong: https://github.com/ROCm/TheRock.git)
GITHUB_REPO=ROCm/TheRock
POLL_CRON_SECRET=random-secret-for-sync-api

# Executive dashboard — hours-saved ROI assumption (minutes per manual triage)
ARVIL_MANUAL_TRIAGE_MINUTES=45

# Optional: protect /api/sync in local dev (leave empty to allow open sync)
# ARVIL_SYNC_URL used by GitHub Actions workflow, not in Next.js

# Python agent — NVIDIA NIM (preferred) or OpenAI fallback
NVIDIA_API_KEY=nvapi-xxx
NVIDIA_API_BASE=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=meta/llama-3.1-70b-instruct
# OPENAI_API_KEY=sk-xxx
